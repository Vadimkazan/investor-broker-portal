{
  "tests": [
    {
      "name": "Get all objects",
      "method": "GET",
      "path": "/?resource=objects",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Get all users",
      "method": "GET",
      "path": "/?resource=users",
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    },
    {
      "name": "Update user role",
      "method": "PUT",
      "path": "/?resource=users",
      "body": { "id": 2, "role": "admin" },
      "expectedStatus": 200,
      "expectedBody": { "role": "admin" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with correct password",
      "method": "POST",
      "path": "/?resource=auth",
      "body": { "action": "login", "email": "login.v1@yandex.ru", "password": "933651" },
      "expectedStatus": 200,
      "expectedBody": { "role": "admin" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/?resource=auth",
      "body": { "action": "login", "email": "login.v1@yandex.ru", "password": "wrongpass" },
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Create object",
      "method": "POST",
      "path": "/?resource=objects",
      "body": {
        "broker_id": 2,
        "title": "Тестовый объект",
        "city": "Москва",
        "address": "ул. Тестовая, 1",
        "property_type": "flats",
        "area": 50,
        "price": 5000000,
        "yield_percent": 10,
        "payback_years": 8,
        "description": "Тест",
        "images": [],
        "status": "available"
      },
      "expectedStatus": 201,
      "expectedBody": { "title": "Тестовый объект" },
      "bodyMatcher": "partial"
    }
  ]
}